# ============================================================
# TravelBeez — environment variables (template)
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only, bypasses RLS — never expose to browser

# --- Site ---
NEXT_PUBLIC_SITE_URL=               # e.g. https://travelbeez.gr

# --- Email (Resend, optional) ---
RESEND_API_KEY=
RESEND_FROM_ADDRESS=                # e.g. bookings@travelbeez.gr

# --- DeepL (translation tooling, optional) ---
DEEPL_API_KEY=

# --- Viva Wallet (payments) ---
VIVA_ENV=                           # demo | production
VIVA_MERCHANT_ID=
VIVA_API_KEY=
VIVA_CLIENT_ID=
VIVA_CLIENT_SECRET=
VIVA_SOURCE_CODE=

# --- Cloudflare R2 (visa document storage, S3-compatible) ---
R2_ACCOUNT_ID=                      # Cloudflare account id
R2_ACCESS_KEY_ID=                   # R2 API token access key id
R2_SECRET_ACCESS_KEY=               # R2 API token secret
R2_ENDPOINT=                        # https://<account_id>.r2.cloudflarestorage.com
R2_VISA_BUCKET=                     # bucket name for visa documents
